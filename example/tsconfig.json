{
  "files": [
    "src/main.ts"
  ],
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "es6",
    "moduleResolution": "bundler",
    "target": "es5",
    "rootDir": "src",
    "outDir": "transpiled",
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true,
